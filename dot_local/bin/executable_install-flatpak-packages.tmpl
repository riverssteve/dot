{{- if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "bazzite") (eq .chezmoi.osRelease.id "fedora") (contains "fedora" .chezmoi.osRelease.idLike)) }}
#!/usr/bin/env bash
# Install Flatpak packages from flatpak-packages.txt

set -e

PACKAGE_FILE="$HOME/.local/share/chezmoi/flatpak-packages.txt"

if [ ! -f "$PACKAGE_FILE" ]; then
    echo "Error: $PACKAGE_FILE not found"
    exit 1
fi

# Read packages, filter out comments and empty lines
PACKAGES=$(grep -v '^#' "$PACKAGE_FILE" | grep -v '^[[:space:]]*$' | xargs)

if [ -z "$PACKAGES" ]; then
    echo "No packages to install (all lines are commented or empty)"
    exit 0
fi

echo "Installing Flatpak packages:"
echo "$PACKAGES" | tr ' ' '\n' | sed 's/^/  - /'
echo ""

flatpak install -y flathub $PACKAGES

echo "✓ Flatpak packages installed successfully!"
{{- end }}
