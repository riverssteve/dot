{{- if and (eq .chezmoi.os "linux") (or (hasPrefix "pi-" .chezmoi.hostname) (hasPrefix "raspberry" .chezmoi.hostname)) -}}
#!/bin/bash
set -e

cat <<'EOF'

=== Raspberry Pi: Package Installation ===

--- apt packages ---
  sudo apt install -y fish fzf bat direnv

  Note: bat is installed as 'batcat' on Debian.

--- Tools not in apt (install manually) ---

  zellij     https://github.com/zellij-org/zellij/releases
  neovim     https://github.com/neovim/neovim/releases  (apt version is outdated)
  eza        https://github.com/eza-community/eza/releases

  atuin      curl https://setup.atuin.sh | sh
  starship   curl -sS https://starship.rs/install.sh | sh
  uv         curl -LsSf https://astral.sh/uv/install.sh | sh
  zoxide     curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
  mise       curl https://mise.run | sh

  lazygit    https://github.com/jesseduffield/lazygit/releases
  lazydocker https://github.com/jesseduffield/lazydocker/releases

==========================================

EOF
{{- end }}
