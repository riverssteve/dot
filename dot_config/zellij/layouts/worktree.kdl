layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab {
        pane split_direction="vertical" {
            pane size="65%" split_direction="horizontal" {
                pane size="70%" name="editor" focus=true {
                    command "fish"
                    args "-c" "direnv exec . nvim"
                }
                pane stacked=true {
                    pane name="shell"
                    pane name="shell"
                }
            }
            pane {
                command "fish"
                args "-c" "direnv exec . claude"
                name "intern"
            }
        }
    }
}
