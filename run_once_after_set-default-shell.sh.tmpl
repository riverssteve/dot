{{- if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "bazzite") (eq .chezmoi.osRelease.id "fedora") (hasPrefix "pi-" .chezmoi.hostname) (hasPrefix "raspberry" .chezmoi.hostname)) -}}
#!/bin/bash
set -e

{{ if or (eq .chezmoi.osRelease.id "bazzite") (eq .chezmoi.osRelease.id "fedora") -}}
FISH_PATH="$(which fish 2>/dev/null || echo /home/linuxbrew/.linuxbrew/bin/fish)"
{{ else -}}
FISH_PATH="$(which fish 2>/dev/null || true)"
{{ end -}}

if [ ! -x "$FISH_PATH" ]; then
    echo "fish not found, skipping shell setup — install fish first"
    exit 0
fi

if ! grep -qF "$FISH_PATH" /etc/shells; then
    echo "Adding $FISH_PATH to /etc/shells..."
    echo "$FISH_PATH" | sudo tee -a /etc/shells
fi

if [ "$SHELL" != "$FISH_PATH" ]; then
    echo "Setting default shell to $FISH_PATH..."
    sudo usermod -s "$FISH_PATH" "$USER"
fi
{{- end }}
