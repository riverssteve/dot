# Files to ignore across all machines
README.md
.git/
.claude/

# Ignore work-specific files on non-work machines
{{ if not (lookPath "Caskfile.work") }}
.config/fish/conf.d/work_*.fish
{{ end }}

# Ignore fish configs on Raspberry PIs (they use bash)
{{ if eq .chezmoi.os "linux" }}
{{ if or (hasPrefix "pi-" .chezmoi.hostname) (hasPrefix "raspberry" .chezmoi.hostname) }}
.config/fish/
{{ end }}
{{ end }}

# Ignore macOS-specific files on Linux
{{ if eq .chezmoi.os "linux" }}
Caskfile
.config/fish/conf.d/macos_*.fish
{{ end }}

# Ignore Linux-specific files on macOS
{{ if eq .chezmoi.os "darwin" }}
.config/fish/conf.d/linux_*.fish
{{ end }}
