{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -e
brew bundle --file={{ .chezmoi.homeDir }}/Caskfile
mise install node@latest && mise use --global node@latest || echo "Node install failed — run 'mise install node@latest' manually after setup"
{{ else if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "bazzite") (eq .chezmoi.osRelease.id "fedora")) -}}
#!/bin/bash
set -e
brew bundle --file={{ .chezmoi.homeDir }}/Brewfile
mise install node@latest && mise use --global node@latest || echo "Node install failed — run 'mise install node@latest' manually after setup"
{{ else if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "debian") (contains "debian" (.chezmoi.osRelease.idLike | default ""))) -}}
#!/bin/bash
set -e

if [ "$(id -u)" = "0" ]; then sudo() { "$@"; }; fi

# Prerequisites
sudo apt-get update && sudo apt-get install --no-install-recommends -y \
  ca-certificates \
  curl \
  gpg \
  fish \
  fzf \
  direnv

# Docker
sudo install -m 0755 -d /etc/apt/keyrings
sudo curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc
sudo chmod a+r /etc/apt/keyrings/docker.asc
sudo tee /etc/apt/sources.list.d/docker.sources > /dev/null <<EOF
Types: deb
URIs: https://download.docker.com/linux/debian
Suites: $(. /etc/os-release && echo "$VERSION_CODENAME")
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF

# eza
wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list

sudo apt-get update && sudo apt-get install --no-install-recommends -y \
  docker-ce \
  docker-ce-cli \
  containerd.io \
  docker-buildx-plugin \
  docker-compose-plugin \
  eza

curl -q https://mise.run | sh
export PATH="$HOME/.local/bin:$PATH"
mise install node@latest && mise use --global node@latest || echo "Node install failed — run 'mise install node@latest' manually after setup"
{{ end -}}
